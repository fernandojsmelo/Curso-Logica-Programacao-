# Created by https://www.toptal.com/developers/gitignore/api/qtcreator
# Edit at https://www.toptal.com/developers/gitignore?templates=qtcreator

### QtCreator ###
# gitignore for Qt Creator like IDE for pure C/C++ project without Qt
#
# Reference: http://doc.qt.io/qtcreator/creator-project-generic.html



# Qt Creator autogenerated files


# A listing of all the files included in the project
*.files

# Include directories
*.includes

# Project configuration settings like predefined Macros
*.config

# Qt Creator settings
*.creator

# User project settings
*.creator.user*

# Qt Creator backups
*.autosave

# Flags for Clang Code Model
*.cxxflags
*.cflags


# End of https://www.toptal.com/developers/gitignore/api/qtcreator

# Arquivos gerados pelo Qt Creator
*.pro.user
*.pro.user.*
*.qbs.user
*.qbs.user.*
*.autosave

# Arquivos de Build/Compilação
build-*/
build/
*build-*

# Makefiles e arquivos de objeto
Makefile*
*.o
*.a
*.so
*.so.*
*.dll
*.dylib
*.prl
*.rcc

# Arquivos moc (Meta Object Compiler)
moc_*.cpp
moc_*.h
*.moc

# Arquivos ui (User Interface)
ui_*.h

# Arquivos qrc (Recursos)
qrc_*.cpp

# Qmake stash (configurações específicas da máquina)
.qmake.cache
.qmake.stash

# Qt QML
*.qmlc
*.jsc

# Arquivos gerados pelo CMake (se usar)
CMakeLists.txt.user*
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
*.cmake

