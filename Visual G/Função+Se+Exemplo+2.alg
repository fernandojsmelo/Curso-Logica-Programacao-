algoritmo "Funçăo Se Exemplo 2"
//  
//  
// Funçăo :
// Autor : Fernando Melo
// Data : 12/01/2022
// Seçăo de Declaraçőes 
var

   cor : caracter

inicio

      Escreval("Digite uma cor: ")
      leia(cor)
      
      Se (cor = "Azul") Entao
      
         Escreval("A cor digitada é Azul")
      
      Senao
      
            Se ( cor = "Amarelo" ) Entao
            
                 Escreval("A cor digitada é Amarelo")
            
            Senao
            
                 Escreval("Cor inválida!!!")
            
            FimSe
      
      FimSe

fimalgoritmo
