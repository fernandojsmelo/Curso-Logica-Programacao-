algoritmo "Para-de-Ate-Passo-Faca número de 10 ate 1 passo -1 Faca"
//  
//  
// Funçăo :
// Autor : Fernando Melo
// Data : 16/04/2026
// Seçăo de Declaraçőes 
var

   numero : inteiro

inicio

      Para  numero de 10 ate 1 passo -1 Faca
      
            Escreval("Número", numero)
      
      FimPara

fimalgoritmo
