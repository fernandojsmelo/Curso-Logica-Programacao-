algoritmo "Repita Ate Numero seja Maior ou Igual a 10"
//  
//  
// Funēćo :
// Autor : Fernando Melo
// Data : 16/04/2026
// Seēćo de Declaraēões 
var

    numero : inteiro

inicio

      numero <- 0
      
      Repita

            numero <- numero + 1
            Escreval(numero)
      
      Ate numero >= 10

fimalgoritmo
